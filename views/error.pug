doctype html
html
  head
    title Error
    style.
      body {
        font-family: Arial, sans-serif;
        padding: 40px;
        background: #f5f5f5;
      }
      .container {
        background: #fff;
        padding: 20px;
        border-radius: 8px;
        max-width: 600px;
        margin: auto;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
      }
      h1 {
        color: #e74c3c;
      }
      pre {
        background: #eee;
        padding: 10px;
        overflow-x: auto;
      }
  body
    .container
      h1 Something went wrong 🚨
      h2 #{message}
      
      if error && error.stack
        h3 Stack Trace:
        pre= error.stack